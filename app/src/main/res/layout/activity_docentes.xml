<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white"
    tools:context=".DocentesActivity">

    <!-- Toolbar superior -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarDocentes"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/colorPrimary"
        app:title="Nuestros Docentes"
        app:titleTextColor="@android:color/white"
        app:navigationIconTint="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenido desplazable -->
    <ScrollView
        android:id="@+id/scrollViewDocentes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarDocentes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- ================= PROFESOR 1 ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfesor1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="2dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgProfesor1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/profesor"/>

                    <TextView
                        android:id="@+id/txtNombreProfesor1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Poll Dikson Pariona Huamani"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:gravity="center"
                        android:layout_marginTop="12dp" />

                    <Button
                        android:id="@+id/btnVerInfoProfesor1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver Información"
                        android:backgroundTint="@color/colorPrimary"
                        android:textColor="@android:color/white"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"/>

                    <LinearLayout
                        android:id="@+id/layoutInfoProfesor1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Profesor especializado en reparación de celulares, computadoras, robótica y proyectos tecnológicos."
                            android:textColor="#444444"
                            android:textSize="16sp"
                            android:lineSpacingExtra="5dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= PROFESOR 2 ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfesor2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="2dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgProfesor2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/profesor2"/>

                    <TextView
                        android:id="@+id/txtNombreProfesor2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Oscar Hernán Méndez Chávez"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:gravity="center"
                        android:layout_marginTop="12dp" />

                    <Button
                        android:id="@+id/btnVerInfoProfesor2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver Información"
                        android:backgroundTint="@color/colorPrimary"
                        android:textColor="@android:color/white"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"/>

                    <LinearLayout
                        android:id="@+id/layoutInfoProfesor2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Especialista en reparación avanzada de laptops, tablets y microelectrónica aplicada."
                            android:textColor="#444444"
                            android:textSize="16sp"
                            android:lineSpacingExtra="5dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================= PROFESOR 3 ================= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfesor3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/colorPrimary"
                app:strokeWidth="2dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imgProfesor3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/profesor3"/>

                    <TextView
                        android:id="@+id/txtNombreProfesor3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Jorge Iván Meléndez Rojas"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:gravity="center"
                        android:layout_marginTop="12dp" />

                    <Button
                        android:id="@+id/btnVerInfoProfesor3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver Información"
                        android:backgroundTint="@color/colorPrimary"
                        android:textColor="@android:color/white"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"/>

                    <LinearLayout
                        android:id="@+id/layoutInfoProfesor3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Docente especialista en robótica educativa, programación Arduino y automatización."
                            android:textColor="#444444"
                            android:textSize="16sp"
                            android:lineSpacingExtra="5dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>





