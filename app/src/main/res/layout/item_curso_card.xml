<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardCurso"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="@android:color/white"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título del curso -->
        <TextView
            android:id="@+id/txtTituloCurso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Curso de ejemplo"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E3A8A"
            android:gravity="start"
            android:letterSpacing="0.02"
            android:layout_marginBottom="6dp" />

        <!-- Texto para mostrar/ocultar detalles -->
        <TextView
            android:id="@+id/txtMasInformacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Más información ▼"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:gravity="start"
            android:layout_marginBottom="8dp" />

        <!-- Detalles del curso -->
        <TextView
            android:id="@+id/txtDetallesCurso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="6dp"
            android:text="Aquí van los detalles del curso"
            android:textSize="15sp"
            android:textColor="#444444"
            android:lineSpacingExtra="5dp"
            android:paddingEnd="4dp" />

        <!-- Ícono de Telegram (AUMENTADO) -->
        <ImageView
            android:id="@+id/ivTelegram"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_telegram"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:contentDescription="Abrir Telegram"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</androidx.cardview.widget.CardView>







